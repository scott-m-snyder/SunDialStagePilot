<?xml version="1.0" encoding="utf-8"?>
<androidx.wear.widget.BoxInsetLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".MainActivity"
    tools:deviceIds="wear">

    <!-- Scrollable container for the text data. boxedEdges keeps it from falling off the circular rim. -->
    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="vertical"
        android:scrollbarThumbVertical="@drawable/scrollbar_thumb"
        app:boxedEdges="all">

        <!-- This TextView will display the raw formatted chart text passed from the Z Fold -->
        <TextView
            android:id="@+id/tv_chart_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:lineSpacingMultiplier="1.2"
            android:text="Waiting for song chart..."
            android:gravity="center_horizontal"/>

    </ScrollView>

    <!-- Invisible overlay that captures screen taps to scroll the view up and down manually -->
    <View
        android:id="@+id/touch_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="true"/>

</androidx.wear.widget.BoxInsetLayout>