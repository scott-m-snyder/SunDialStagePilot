<?xml version="1.0" encoding="utf-8"?>
<manifest package="com.sundial.stagepilot"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:label="SunDial Stage Pilot"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:theme="@style/Theme.SunDialStagePilot">

        <activity android:name=".LogActivity" />
        <activity android:name=".SettingsActivity" />

        <!-- Make TestParseAndBlocksActivity the new Home Page! -->
        <activity android:name=".TestParseAndBlocksActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>
</manifest>